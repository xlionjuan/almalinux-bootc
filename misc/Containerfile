FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:eb71f9f99a7f947c868fdb4bd529481713fa2e181b47887cdc8aab11b1ada673

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
