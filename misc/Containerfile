FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:f4a772513631667ca517c20c2cded6a83ed7e640c77893ed506ab28d4453b8df

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
