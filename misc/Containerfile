FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:d5e2c4b8605ad5cfc39615ef1468997ad9b0e409bab1b991d6bc086edcd6f2b3

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
