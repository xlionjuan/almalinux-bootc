FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:39523882b22a4ef0975cb76c9573d0ebfca10fbbd6f4c4a765aaf46885967e33

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
