FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:1f7f8fe742f0701ece5237069d8f8c2ba484a7181cc3d638f587adb376e7a7eb

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
