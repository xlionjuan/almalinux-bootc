FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:bb0583af96f902cbfa2018438f9d81b579629e66b4fa0e2ecd9e9e316cf9f083

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
