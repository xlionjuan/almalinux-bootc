FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:abf3e0c20876b8fd178cd2418992d49d4eaaee3300eb1652cfcc24dd48faf202

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
