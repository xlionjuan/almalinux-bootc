FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:94900aa745bb2e0236b5df0f329e48256716099cb2b243154e320aec31250ffb

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
