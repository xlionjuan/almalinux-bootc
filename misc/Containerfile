FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:2da473a6ef6fe6263c59b01304ebd6134edb34aab0a623173563f232f0b9923c

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
