FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:82e741489f99c9bc8d4de0efcbcb131def8ec227d0b7e1b7608e04242b48a4f5

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
