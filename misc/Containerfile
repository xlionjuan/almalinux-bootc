FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:6d0c9d9ff2eb54add1671bfde8eb8e2039a00b3fb4ebc0e69c4a69b18585139f

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
