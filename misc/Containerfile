FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:cc41761368bbba6a936d1113dee4e1ad472cd2443a3dfc576037843214f5ecd5

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
