FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:de45736bb638be11efb3876cd81845f5df482d9342b31a7fc4a905fa419ad5dd

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
