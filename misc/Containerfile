FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:03666415860be9ae981f9c567ec5ecc1ca072195081c49c75c636ed7afad2789

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
