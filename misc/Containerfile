FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:0f9edae3e89835c62d94cebba4c5670add58cbd4514b96e5b479f1a476464688

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
