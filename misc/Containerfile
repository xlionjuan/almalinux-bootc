FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:471fb27f7b0c6286a16d4c8239969c0c6efd64cb774aa5a3d5099b33ee8e6449

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
