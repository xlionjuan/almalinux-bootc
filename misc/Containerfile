FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:4b8bfe69d398e97beab626f77ba333258a56956efed67f8ce3c123fac5c8060c

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
