FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:9e8cbc2d99525bed7c45f7a86e226e2aca5ddc6fdf48ffbd7848b8714807bf86

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
