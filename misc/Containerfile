FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:7ea130b6a4535d0c4933c7aaef2d997d44d8460045a2d36e58e9ba3f01347ff3

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
