FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:873b521254fb0223050c625ede567ccbddda2dd52beb859973d2b9a3042e6034

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
