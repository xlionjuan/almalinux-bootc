FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:b03f7d360b72c4f183d87ac23a8040ed8742d6c522048b3204966e1413d746b4

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
