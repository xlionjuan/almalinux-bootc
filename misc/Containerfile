FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:3f3987b45e71ea14d3a4bebf7fd7463ee8243dba45aed18d54afaed05a91607a

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
