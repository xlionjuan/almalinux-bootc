FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:459b4c2c4872d43bfe9f0eab4dc912b06cfdb9044ac94ff33620d4fa1d295f42

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
