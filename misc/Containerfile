FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:46708441dcc6468c6f04521aad2ea42fbc60fb8511cd48dc473d887f99724437

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
