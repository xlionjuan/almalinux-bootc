FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:79ad7226a120b647a04c4b6c81425819dd0cab38214ec5e75777851ae8bceb41

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
