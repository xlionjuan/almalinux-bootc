FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:6f1a9585bd5041bc916b4c6a0fd357bafb941f5a828d352fb8c1d81b27911091

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
