FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:ce1d5ad5ed30602d1e0c083796d6d53a4d2159b54266bc65b8a6e5d185b48f4f

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
