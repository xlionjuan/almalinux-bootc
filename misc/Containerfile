FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:6f8625f12b008353354f0c38e132a9c460be7a2847ff3ecf5f6360b670d5c0a2

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
