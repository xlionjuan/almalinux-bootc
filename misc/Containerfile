FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:c7fc0ffea1067bc731b244c02639051462e461b0e1cf5325fb2005bcafdff12d

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
