FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:73c1d47d342602c3af7f879098ebce4b1c66a7c22e183e12dbfadc7f43dec35e

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
