FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:4ebec367d0a97de5afd9970c799fd740d914fb0c0e3bac5f636eeb151f0ba30a

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
