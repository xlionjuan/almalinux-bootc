FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:9911c757c90445f360dddb0d7c6b754739709cc791ba22f0b01feaad651de646

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
