FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:b348a34758fa25d4904f626f877ac2e0c1d879b296237525d3ac5cddb8f701d9

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
