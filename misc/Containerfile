FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:48936450f21f01e7ba458c543f5432a06d912a30a9b0dcb7e2b003989e02bfe6

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
