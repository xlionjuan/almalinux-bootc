FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:9a53f22aa27da03dd3bd28f02561cd3902c778bf1b36417e91b5a1bde1dd96ba

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
