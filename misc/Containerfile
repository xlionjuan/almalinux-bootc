FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:38c6270d34ecb5322b4b00520bdadd9255644b047913d3c65249a4dde1153b89

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
