FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:f700ed83573b1719028f45e6009dc4d7e588031495692281d315bde9e40c2c46

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
