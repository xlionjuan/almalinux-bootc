FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:88df556d50c8da9e9a9d07b21d54acfee5a757e5cf910b88343eed2f7039806b

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
