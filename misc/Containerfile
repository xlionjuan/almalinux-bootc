FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:80e11a97ca34309e26291a34e5aab1f786d4f97911e1ad4b8e20c89d8e933be6

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
