FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:94365bfec21f3043deed62e4f008860cf6cca5d838ce2134817fbee79e6c9c3a

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
