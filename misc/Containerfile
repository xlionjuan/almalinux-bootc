FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:34b32be718e949971124057055bfe458a713fdef34f8be6393c9e03e17e65470

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
