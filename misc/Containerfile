FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:5711f61d047d8f3c59f41e4a956b42bc0b2e56280cbde5a273750fe9cd28e83c

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
