FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:87b2e7ded46ea85d9f7ba876f8d800ded6f09e821c6f9bab7ed529b17c2acd68

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
