FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:3b3500ee1fa9c01770b49dea8b8a82673138174c722e705d8e5728f89bda89b3

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
