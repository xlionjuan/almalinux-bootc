FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:3ff06c2861b0b7282304d6fbfba419696d5c760590614fd25c299bf15e3b6e8c

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
