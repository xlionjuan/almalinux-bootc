FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:e51cb7e02b28a36b92aeeb87edede3cb08ac6ca6fa936d265436a8d4c335295b

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
