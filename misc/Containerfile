FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:45054fd78397e9b5625bb3650fa88beb5fb49da010d622e969482fac78ad17d1

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
