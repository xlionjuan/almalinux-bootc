FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:83a21178903711c476f2a9a349188ce3d059d2567129c0af85b4670bbbfb9a69

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
