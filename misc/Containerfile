FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:513b5d8e8b52dd2af00e0922d05a1daa9b0edf3daedf67e4c6c902914ce09a07

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
