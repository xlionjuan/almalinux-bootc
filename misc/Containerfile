FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:42c432489ddcfc224ec052eebad3ae297de422545091db92d2d6a471171032c9

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
