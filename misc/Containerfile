FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:df2a5d3d4bcc60d1ca80b61d54e005fccc67bd73002b26f8aa67ae8edcecc328

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
