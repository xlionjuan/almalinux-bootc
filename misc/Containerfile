FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:cef106f15d93d0618215987660938519ddc6ab22794c84b19c1e54d3e03943d4

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
