FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:d23a57e3d72df3e6d73e97531f5577e77c6e236a3ab5cd7085837d8198516595

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
