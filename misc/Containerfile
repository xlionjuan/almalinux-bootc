FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:b6e4fb52919bd468134610cd672108d51988607a063347018845dac86e039fff

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
