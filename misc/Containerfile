FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:4c87a793abd5bd13ff3280088a68c8f583fb5a89e1c54a83a5f8d31c7a707a9a

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
