FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:f89435af59c6ea23cbedc4ca601826edc372ded63e73b4d8a1c287047b292e59

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
