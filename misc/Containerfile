FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:e39d7d0dba5ad63bb9b8d987ae2ff741412c70e2bdddfa4acbbe2a996b20f85c

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
