FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:ee90913fddad132f0c2515a08d0f984f9a13ba3f32109781ad8ef52d46cd0f66

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
