FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:bbc0864f06cdb61d0a6e17afc983d1a20c0053a5888077777428b86f735f5b8c

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
