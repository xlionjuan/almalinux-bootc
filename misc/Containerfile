FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:3411c70ad4d5ad30b28fba06e3d825dc4106a4b97bb4b4e3fc0ae64b7857f227

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
