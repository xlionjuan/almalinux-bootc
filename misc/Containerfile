FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker@sha256:a4bbfd42c27b7ae157d310120e55fce8f66ac6813cfbd43db9cad9ffd65cb2e6

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
