FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:1bec556c4d496b3aad1f44d70c7b2c0720429d35bdf0c50bf94670b6b7aac5e1

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
