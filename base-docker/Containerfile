FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:b648c476fb3b715ae6ba043d70dff60c710746debda6f232a92497dd30e34be2

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
