FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:b863574dab2cebb9c7f9de0397883183f19a76e6c13edeb1bdb32fb32f4caaa2

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
