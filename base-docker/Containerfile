FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:ac84765f314b12a13f115269777448cc8d03b40a1b3ab51a660fc8b55fbbe757

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
