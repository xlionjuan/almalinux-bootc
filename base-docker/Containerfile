FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:c1171dd08a829928139f8ecbb8e17a5fdaa5b795220bcca4aee289b277bdee4c

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
