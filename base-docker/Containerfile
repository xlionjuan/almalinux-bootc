FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:2c80707ede9dc3606af85500fa9911e14137a83d92e6305ff53d40f7ae880a3c

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
