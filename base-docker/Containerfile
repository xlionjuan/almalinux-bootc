FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:742d94046dd0cff1dfbdd6b0a9ab7683f6f3564b0726f045ac1b5701ade98c30

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
