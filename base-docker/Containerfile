FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:ba2b8aabb5b9203a441677f9c03f73589721286a11213b8115c6996c7cdb7811

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
