FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:2898550046fbf2c3d89fa39582625483e64394064c27ce7d496470ca7e68489c

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
