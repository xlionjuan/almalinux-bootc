FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:7a66a1805043342096450d76ed3092c0a40aafb963342bdc42e7b6b367cfb1b4

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
