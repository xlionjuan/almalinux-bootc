FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:89cefbe4e0c67dae37c677d0f73756974397d0195383a0e0d7fe6c01585bfef1

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
