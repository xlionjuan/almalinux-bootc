FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:7e8bdee47553081479add9536b39627c1a97b164b2d2eebe4cf51934bdc8c102

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
