FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:7c88225f7a1b0fddb6ccc8adda6e9e58d67e21f6097250fa4be41c0d849e7ed3

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
