FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:2ec524b2c4fbabd8b5facc3ee4dbb14cb028e1fb4c81e3fc1037dd95d534388c

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
