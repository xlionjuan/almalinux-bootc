FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:94ffaac71fc77689812dc813a18f8c0dcb2291356a03159e3e7c3b4d81068516

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
