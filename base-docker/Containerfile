FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:a665b62bbaab17cbfaaa1924a411d6ce3e4418ff58d80c0aed548b9e653078f5

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
