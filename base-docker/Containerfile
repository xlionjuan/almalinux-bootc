FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:9415d925ecc19de71a73b724bc8cf4963fb71966f818e6a90ea187f9a2aac292

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
