FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:c03ea82f2eef0b7814260cbbc6a98252c7fa4d6ac5551f8413b32b3fa3a541f1

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
