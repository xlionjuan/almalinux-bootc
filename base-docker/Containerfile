FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:fd07cc947cb5dd79111268747011f6a39d051ed213995c3b39c0b0506221fac7

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
