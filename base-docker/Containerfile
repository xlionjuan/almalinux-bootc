FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:b655fb0cd0b469c37c5e6f1f001e747ee05763989939d505206f8a266700c640

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
