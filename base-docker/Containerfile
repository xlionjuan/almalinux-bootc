FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:d644f6dd4c9c6c5efaedf7a2f849e989f5afb5e7a6f2646b5c56830290e6b683

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
