FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:e47c893810c892ee96831c3c47fa2b744cbd4d0d26374cbfaf05f8e7443199f1

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
