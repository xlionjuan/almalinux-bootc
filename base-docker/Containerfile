FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:a7df8dfceeeca0b996a00aac7634c1a25db693ed30e147877991e60b2da5f8e3

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
