FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:f9a3e789708a5340b836d560178f81cf88157e0ad11cc1ef6b04910d4bd878e7

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
