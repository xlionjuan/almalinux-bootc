FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:f0d94ce695001f7920a7eaab062a197d4d0ba28da92ba5576b2f2139edfab788

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
