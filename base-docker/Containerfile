FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:4abd11fd930c9b607873122cd06b1128e7261120126939f71a9e6f3af0e993a1

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
