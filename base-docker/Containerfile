FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:f2094e6188757d70ba5b920ce9c50ee20cc64a2f3d50a3d022b01d86a87cae70

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
