FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:360868e228d23c08a5382ae1c82a2cec1400fd159e4b9fad9939e7053cad565a

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
