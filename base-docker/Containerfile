FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:e1b9a90448ddc5d421e605510ae2d9cd3faa290bd94d6f825d8df91b26041b1a

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
