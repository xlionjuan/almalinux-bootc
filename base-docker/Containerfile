FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:7af00eaca6e9442ee048ca48390b7fed80d82a0d3b9ecab6a4a68956bbf2ed95

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
