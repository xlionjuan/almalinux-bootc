FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:4a4a37783900e31ffebd6f155ae61d1925d3591dba230514e832d8e07d8d5633

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
