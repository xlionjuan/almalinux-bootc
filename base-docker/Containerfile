FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:0c68330967bc5ee1915c1243f01d0572c1e2e11c485a4547b89684a4f566e15c

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
