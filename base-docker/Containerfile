FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:da67e04827c738d7c6111d0501fe43433fc4237e8822622f8075dc37013be0a7

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
