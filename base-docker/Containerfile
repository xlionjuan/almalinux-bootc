FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:4d47c5f6eebaf6f50c06e88135f849c21400461b8b77413d66c679e070893a5b

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
