FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:9f9339c79a868cca8aa1caa73733dee6973d2df2014c4b5259fa7a88120c80d6

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
