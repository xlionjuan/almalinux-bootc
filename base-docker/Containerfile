FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:4a0fb1fc21c29cf333165a5948e7b8fc505465f2bdfdf1a0a5cee178595305f6

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
