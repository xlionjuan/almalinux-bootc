FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:de2c0966d0f94c1576817b0a4844452325623c9b119748960432e33f6d10d2ab

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
