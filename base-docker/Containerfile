FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:e6c3116c1fb482ba849aaa57dd16de51e7a0b98722553469bce630977cd78119

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
