FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:ee2f2eada570b9044050d301e35583039072ba5297b31d359ca6c02a9e52be92

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
