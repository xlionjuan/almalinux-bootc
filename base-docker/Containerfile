FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:7cd456c1701f5e82fed6a3b4d06ecea78d9c571fefd6e6a709222fb58067da02

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
