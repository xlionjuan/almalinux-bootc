FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:3bb8d1a953599ba6ae94cd51e9a35ea30894dfab4434f4141e4d4aeb7720d24a

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
