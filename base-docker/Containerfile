FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:35ace84bae90601865920816cc9525e332644ad3ba323cef9a0112d6723dce39

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
