FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:2726fd4e669be699f476d29b7b2bf6537d24505f77d54bed40966ab1c5efa97f

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
