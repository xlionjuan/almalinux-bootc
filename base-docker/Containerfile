FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:9df9fad720c0579dbd470655fdf58401c9698aa4c6f7d4bcb88fa59bfde46a59

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
