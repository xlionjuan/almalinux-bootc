FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:57c64601c76bd90942d0dc3e8a2a14cb0de8c9bdfa7b56c11a76a72805b0231b

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
