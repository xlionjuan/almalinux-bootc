FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:724e565e95f6b3acc307f1a8bcb39e957945340b30e511190f7c4e3448b5e4da

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
