FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:49005fc906dc6fc8cf2acb9c86d14f177cd722ffea7d87631d12ba57b88ade8b

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
