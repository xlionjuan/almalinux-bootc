FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:67cd50020e13234405200096bdfa3843b704c57a195c4fa6812496d1c30ac33c

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
