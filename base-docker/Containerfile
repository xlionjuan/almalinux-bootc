FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:d82d250f74aa925f25860180a7771dee5d63490fb547933852ec00927c736551

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
