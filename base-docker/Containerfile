FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:b1b07a76aabc32175c3c54407b56547a5017c8ec851fea77c84e968ba38e080e

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
