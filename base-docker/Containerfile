FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:07590bc99d77efa67581babde5237a6a06b2777722e37bb7463932d94bef8ee8

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
