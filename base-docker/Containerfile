FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:1eef8f5d7115bbf4d7c7f41830ded490a38ec7c95cb4dab049d5a6260781a98b

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
