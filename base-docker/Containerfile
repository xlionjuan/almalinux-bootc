FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:a308922bef72957130742ed6035d3d5515700ae2ef86d2a6c4f2c04647c2855d

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
