FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:e24429fc13c717c9c4e5c367ef35c32c51cb287405ca0c976733d566968a6d94

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
