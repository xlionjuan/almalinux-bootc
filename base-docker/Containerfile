FROM ghcr.io/xlionjuan/almalinux-bootc:base@sha256:a52a28e8baa39a94c8aa0576a567737061ce3b2b90a96caedd42afee5ae231fc

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
