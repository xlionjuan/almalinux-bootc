FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:c16968e9f22c574d4be506fda5d3a44a0d1396c87d6293926ef2030aa9824ec8

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
