FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:51b4d434ced43b9fce8aecd620935f85084a218628aaabe4cc01cce3fcbf4c9f

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
