FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:53e9b7f7ea65a651770a31b397c7697a31f61a8123178df4057576eefcd27e26

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
