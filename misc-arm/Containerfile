FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:9c42ccce554d522d43dcc1f4049f23641c79b7fa1d6afe4b85799836c71c8095

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
