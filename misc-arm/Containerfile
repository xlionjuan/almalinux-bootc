FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:b1dab02f162425661c85172ce981cc72a36fbc41f846d464dbf1570795145d3c

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
