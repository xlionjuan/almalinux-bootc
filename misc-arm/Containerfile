FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:2510f0047d0b313b4861be30ac80b6de3f191e674f8ae679d766b00f66d05f98

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
