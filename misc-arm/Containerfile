FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:3583b6c494ff37fd14a4666388aead14d13f612d56a4112e288a754f693b14db

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
