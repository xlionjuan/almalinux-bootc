FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:cc667a9ea4d832a528ea6322a6337cd97d5523293f68f945c9c773387f880b08

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
