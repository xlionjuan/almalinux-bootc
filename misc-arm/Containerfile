FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:867ee8ba93f47e440b25c40bba01a73d68b24cbe17024c4ed2394b33c737be7c

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
