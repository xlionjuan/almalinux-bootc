FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:4d35e4abd98bf92af04294c02f21b378d58f234a0170cb9434211e5f81b312bf

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
