FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:bb8d508d5dc597c258c7c194005caa392ba316f22cdf674c9d076a977df685e2

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
