FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:82ee352297d5d6b6dc4ba0c0a17c147cddf9a9caac7295b768be6a0ba1d1682d

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
