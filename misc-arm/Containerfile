FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:a58c29125bb01bcdbdca0751c2cc0ebe5b9ff5795ef7e14b36eae3c9c2f23fe6

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
