FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:51a6bd78bade38252356bd83cefef8ad4d750911470726541cfa237107324e6b

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
