FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:52b92dec9d8131894bfc373b3bb26b3f949efe71bad46ce855a2c2e3ff3bc408

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
