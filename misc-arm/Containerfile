FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:70fd1af94f651bdc47bfca89423289a8a135beb3cccf9641153f00b12cb9625c

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
