FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:387cb77aeacf94b4cebb71eba5caee7ae4ac2faf834a811e47d2da20d39d3cc8

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
