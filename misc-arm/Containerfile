FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:8fbccd9e33235b61a5a51c3f9464cc891cfbb32d214dda5ecbe36a28d438b8bc

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
