FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:866b1ae5d78d6d61340af8411c5acc7db38cccffd1416afca0bccad0de85e324

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
