FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:97829783785de4ee5d4f3121a11bce0bd9b974059938dfeff6fef97b0317935d

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
