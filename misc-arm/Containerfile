FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:c5b3213631671c9abf765e0b808f88a43708647bb4e24554b8029e417a5ae1d2

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
