FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:67fd66334451e4bc7ea1155cd82110f7c25dfab53b7a27ec56d229f41c5d0930

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
