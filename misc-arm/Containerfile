FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:e86e8d30d556657ed1b74f49ca57d5b721e16b27673f42994050cddc7d77c07d

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
