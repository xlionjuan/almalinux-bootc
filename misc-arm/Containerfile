FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:78803196a49405cad25fb5d7b5ba140dc716dd42963588f3ca3ae2018593be13

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
