FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:e5f8dd32aff12ae87eaa7d0630d6c1ca0e311fba53d3e6d86987bf5d8c852b4f

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
