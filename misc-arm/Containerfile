FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:deb24cff0f8cd6ac2d5b2c094c2d51a64a77c0d8ca434aeece335190cf96b8cf

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
