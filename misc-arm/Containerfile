FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:c7d3f13dd1e78cfbbfb3f94ead654b98705b9c5df7634fea9c6c4304224d2741

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
