FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:be27304d9d5685356ea2e1f58090729b294f77a970d8cd0145c894566cc8fab1

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
