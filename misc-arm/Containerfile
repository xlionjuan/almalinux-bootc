FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:2aea1701154d5f4b567d6b1536ad33b834b8311afb75968c6bdbe60adde5b5ad

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
