FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:b03dbccf36ae95274ef2e98a78e4d439828089a1646aa4c59cbdede9c30502ce

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
