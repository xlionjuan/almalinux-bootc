FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:9cf108748dab25231c805b32ecc1ffae61773d871fe9f1fb6af2c2f2e46573d0

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
