FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:b041dc60602689cc27321a764f51eee0e8f21f78ad4bb152b99ac54d0b171ada

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
