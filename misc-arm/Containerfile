FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:79d84b3ce6fa41a0e2f0008de6b9d63dd7ce4f6b6f1315ddc618f907d2a4e1c1

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
