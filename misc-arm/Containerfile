FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:93e93f12436aa5d7ca8881ef09b56e1f58595490174b600caa29b377cbc3b714

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
