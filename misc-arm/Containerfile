FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:4005f65ce31caa7e4ff18bf4425adc9c17327d544ab4a99faeb2c8134d56ba0a

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
