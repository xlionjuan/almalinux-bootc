FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:f03c5e429d889da813180fc3dd61112764db2ec8726f758a39600dce09a13551

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
