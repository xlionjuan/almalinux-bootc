FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:ae3ba4ab41445150f5e553c79daf9cd1978619dc9b63c7e5a16e4972940cc891

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
