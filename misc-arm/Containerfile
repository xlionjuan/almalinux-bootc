FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:a5d47c5d65d623be6b1f49aa72a790e026a99c01f50bed43e6ea255e887d1846

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
