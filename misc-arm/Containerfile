FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:5813709cb268bc0bc42e4c79eff05b487859c06b41ca438967e8a41b7d609964

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
