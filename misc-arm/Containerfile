FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:e1c3832ae080f9959d47b41f13260bc63b3ed7b57767add17a18e4f40aa389b3

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
