FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:37551ae46b366c354c281fd8e63dfb7b238352d77e60836b26e91e852ae9fc1b

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
