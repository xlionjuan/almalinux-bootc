FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:cd120ed7ac714edd700da3202556b3873c6e063c4cabbfd4209cc4ea2b953a92

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
