FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:2eec20cee3a96252245608d0797795d625f5ae5e3780b08160d5a714e36ff9f7

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
