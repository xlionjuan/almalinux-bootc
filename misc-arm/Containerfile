FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:0d24422beae42935fd41dd16c2f4a868c07d6f6fcc2835d8fa6fb2ccaba9b6a8

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
