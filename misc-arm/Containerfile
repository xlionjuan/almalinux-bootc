FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:30bb83c4c843309959f539f67ccc33195447be86ddcf2488bccd582cc506083a

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
