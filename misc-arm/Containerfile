FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:1cf8bf99635f7f1cdfe5287c043dba51e5b5cf0cd2df8009120ef8aa63b55f20

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
