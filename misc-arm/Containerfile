FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:273952bc8016643202f4659e78a1ca4327c97a463da879585662a9042c11da45

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
