FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:f8f58eababdf4223d167478abc5f96aaad4cc0d3ac9d70f8a9c0d826d2ed180a

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
