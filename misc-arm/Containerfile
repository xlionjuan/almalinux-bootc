FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:1b92ad0cb7e71bfc9fd54221d8359292d0e478215c24b034cace852f38daba88

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
