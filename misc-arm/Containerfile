FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:7ecd1c5a88eb338dfb80345823f6b5b0fadd650287cc9e700958b5c2829297a7

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
