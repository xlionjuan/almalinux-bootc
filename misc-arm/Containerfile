FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:a6ee4eab7b763eaadcb309b7024c007839dd4dabf07aab1f791cc44d650d1701

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
