FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:f4e19d16438b8bfd84b8de1623001e991f6d1a5193b4a659fb3195cba1057b42

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
