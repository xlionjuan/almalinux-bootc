FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:795e15059d2022b788dde6b262c4c71baa59e9a20701e55e882ea5b408995a06

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
