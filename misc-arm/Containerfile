FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:981f6f45a637ceab11904800004b97203bb7eab579da8771e593751c6161f4ba

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
