FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:1b1bcb395fdaa5057f620608bb1aaecf233d3ecd75a266d8281d85ffc0e29396

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
