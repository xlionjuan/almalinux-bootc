FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:e600ec65e40530b61503260216f36fe0775a490030045c786e794f31eb09594a

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
