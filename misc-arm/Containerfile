FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:63d5f610871574203141d48ab42a508733ffa5d23dd107fefdc879c0d4e643e5

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
