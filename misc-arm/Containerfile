FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:77a6130306a572c7d41281101db0edcbc0a90195e0108e1e294ca4255eb2afd2

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
