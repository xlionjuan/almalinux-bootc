FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:b1a599d44d880d3f21ebba3e879df043b4fe946bd542c8d2869a08c1c4e6893d

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
