FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:e99d5b3cf3484d1e3f86c1a41e0356e4260871ae28bab139a88a8c4743435b2e

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
