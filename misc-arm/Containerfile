FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:ec85bf5597024eb8d7c6320761ccb7771e2e6fe1495ab78724f71bb4b37ded61

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
