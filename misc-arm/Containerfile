FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:17717189f5839a5d2dd5e259b1eedd3e131ac72d1e8aba39d4da8ec4c6d323ba

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
