FROM ghcr.io/xlionjuan/almalinux-bootc:base-docker-arm@sha256:275b2f7a5a591f30ae61959d988786fc6629a4ce9edccf2298af8a1019eae13e

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
