# FROM quay-oci-cache.xlion.dev/almalinuxorg/almalinux-bootc:10
FROM quay.io/almalinuxorg/almalinux-bootc:10@sha256:cd5c9d9357dec7a9ecd01a8312f7afc853f865fde8105e742d53b1cde3b2bb19

