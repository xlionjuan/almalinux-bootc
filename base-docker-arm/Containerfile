FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:a279d38c4cac3a4c229a676395a266a58cf22551b3e72e571fd88ca5e29f1a66

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
