FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:5ab72310833efac4465257863165b62ca12be8bcbcf3f8b98e619107fafa8ab9

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
