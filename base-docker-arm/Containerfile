FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:f349782c5715df3f54aac9e98a6ccf978ba110e9c05fa2c5da03462c71a3c265

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
