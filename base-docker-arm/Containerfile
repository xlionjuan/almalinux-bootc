FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:c740bcef20462133fc8777248e5b90de74429cd5d453a8a15735a728467eb977

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
