FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:2455b4a20919756ce321659135562f5f98e9297809739882e45b051a2d83063f

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
