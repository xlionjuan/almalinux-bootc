FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:2232498c6985e3fdbd46e28096effb6d1dd460f3e4a5328665d95c01795b382c

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
