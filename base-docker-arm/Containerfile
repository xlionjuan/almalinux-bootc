FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:9310c092c94967a75cb275ad38191572e5b3540fbe3ff48865a4e8ef255f69c8

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
