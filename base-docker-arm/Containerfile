FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:26a12ded00b364e518f3a65af42ab079d2d0561b7d9c95e7fe2bc6f0285065fd

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
