FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:ad498995f604f2c7a5f905a63c8e2ee8cc946bc6365f9f7a9cda71725c198f60

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
