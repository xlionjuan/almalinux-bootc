FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:7fd4585534b98d7fc9d8b8bea27c1244553a149aee50e12ebe75136ff42a2aa6

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
