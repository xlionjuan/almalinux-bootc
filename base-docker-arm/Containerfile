FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:7b20afc79a9b268ee3fac136cf678563a48ae12f297c0846277c978d5581908a

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
