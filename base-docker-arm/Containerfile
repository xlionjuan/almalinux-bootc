FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:71d2da26a8e7847504ab1487cc5c8b8062595a3232720ec21feccb170d394d9f

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
