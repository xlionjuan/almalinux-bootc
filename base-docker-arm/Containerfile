FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:c185a8cc4459b5097b5cb0435bb38d1c7a7a023b10ed8b71099bbddd2d75a0c1

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
