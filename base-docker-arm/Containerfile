FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:648156123927f3310fd10559741b105502547debdc80432692c4cf520fe8b9c3

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
