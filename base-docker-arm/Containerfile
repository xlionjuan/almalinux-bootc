FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:75dd08de475cf9fb1826b0ad958ee9b83f950880ef649dd2a5be2d5076d9e42b

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
