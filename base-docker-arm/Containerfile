FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:b8dcb168d1aca29f346938a2a6ee3d8901de005835dc718fc9b0d4e687dade39

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
