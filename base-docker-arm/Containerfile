FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:b8ce45a162fbd4c0298e5b1087cbdcc3ef8f6bc8d96b890f273a631a7f061484

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
