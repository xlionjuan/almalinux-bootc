FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:14d84e1ccb9635b5dc737ca7e24ad47ad19fc45199d77568143ffc00a048f1d3

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
