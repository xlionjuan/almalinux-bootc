FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:c180ab5a7fb2890c4ee936bc1ca035330789e777e8af1a9539b5957396c7a798

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
