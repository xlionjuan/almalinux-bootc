FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:ef4f8e29d8e92cb34c108b6f86abff5d9b92b405cc312287a61de2dd46049b5d

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
