FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:32c619103c9dedb7379baaf559689e862b6fb237525d5a1104dbf3e5340e08f7

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
