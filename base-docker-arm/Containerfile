FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:75659c89f2a0af0ed6bf1fa2e8359503494d2c14e177d257766b5e894ae2c548

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
