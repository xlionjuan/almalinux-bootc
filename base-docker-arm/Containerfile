FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:ae381db3d48ad5cc2b74223396828253ef8dbc3756905bd8d2d1a391bd61562f

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
