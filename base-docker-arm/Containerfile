FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:4382d987e284d581528b23e3e12c42c11c2f0ae98c95f750a27d7150d99778af

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
