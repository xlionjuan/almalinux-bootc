FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:566525bdb98dcd4a0874f8717a811953a1fd6671251423cadc3e27d3231248ff

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
