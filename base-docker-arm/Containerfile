FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:3ebeb9357e502ffc3fe5c4af8e126e266e5146eeec99809ac72b47c9ab17f873

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
