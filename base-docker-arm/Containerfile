FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:28c3507008cbc3513f533de43bdd58e2cd4512ced295329eced687f219560fa0

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
