FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:f89fc3f7278312e408ecc0747de9b7af764ca63d8508828d0aa95de182e77e31

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
