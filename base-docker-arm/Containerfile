FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:0ee7ab2a4d8599645822861926b85d3e06bf16912f972d6ffd6bc2a2276ec558

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
