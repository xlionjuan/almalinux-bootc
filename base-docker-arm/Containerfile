FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:be540e879d8cc3421466eb344817a484d03d4fdcc67140af43d69b287c3b74a8

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
