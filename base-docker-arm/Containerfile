FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:c9a9e866f354d51d8ae1941128db7eea3bff77655cebed82c1044d69dfd5a935

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
