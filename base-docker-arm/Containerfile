FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:051571314dd25b559743d83b15910b71a3480e2e3336d250d6c3cb97b420630f

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
