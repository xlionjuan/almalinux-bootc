FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:c72e76e6104e1e8712f488278b6ff07ecd0a865944f28357f1886d8d50e46613

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
