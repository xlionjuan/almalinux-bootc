FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:6560d38f8a9178132fce2546f8cea6fcd309ce22897ec6eea6a02c028531799b

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
