FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:5b413a93b21a6c1f8df00c5cfad6896e035effe95b99d3d72d44ec6c941598ef

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
