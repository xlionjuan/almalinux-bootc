FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:6228a81d709b2a6bd6e0a4877ddd177ee44ebc4cb8743c533b8275e75267c081

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
