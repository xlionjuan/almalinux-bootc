FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:ab4763a9b37c9c35986276d0f92c217079c1b897326d8f4ac446cca2f6ca4c61

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
