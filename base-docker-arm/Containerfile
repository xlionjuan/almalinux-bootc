FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:671942e39ebc7a3783a411d23491b2f22b1ae7f75bbf1f59cdbb7c5a0d83fb7b

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
