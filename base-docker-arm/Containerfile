FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:e354a9db761e845dbdb40703a4ac6bef314e64b0dafb390dbb87331ec10c91ca

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
