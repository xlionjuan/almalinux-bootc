FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:493008398300fba94c078b758ba942d5b18555cf14bf866c7ea67d33055bd6b1

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
