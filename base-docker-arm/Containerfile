FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:dc5a1196607c280976b9f53ba63d395a76d710083a952fb492e36d27711379b7

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
