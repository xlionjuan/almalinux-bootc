FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:88d31c6f08a34bf0c59b3a93fb20e92dcd470dd8cd643716919e7c4fa2e7f1be

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
