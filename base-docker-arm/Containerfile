FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:8b3e73c4f27b332c1a061e54055fcb905a14cea8596787b5ca52392aa6ef67d2

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
