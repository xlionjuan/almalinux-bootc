FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:159ae6001b3443e34437977ce5eb34afe36a07bfc9909b2e1f5f637b081d20b4

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
