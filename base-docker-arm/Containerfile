FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:3f2eefc7c3c79cf68dde3fdaea1a890ab75df7217645e8b2024d4898502a0914

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
