FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:c03bb05c275b83a0ee856f2541fd0f467d216478e686bf6cc2180c7de14276f2

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
