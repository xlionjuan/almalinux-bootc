FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:4943d9fbe41df776a57e31d847b4e3a049e94e677fac2c148fdd65ffd8dc9821

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
