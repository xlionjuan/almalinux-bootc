FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:272acc659e37535332a75bb7035c9fd1771585c0158acfc05b632fd1510554ee

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
