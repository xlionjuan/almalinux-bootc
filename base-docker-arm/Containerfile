FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:bbfc073eb04d0953d87038d27e575335b8e1c0d9a4784825b374cc1a3efa8403

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
