FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:fc45d8e8d0929271ebb63025d65c89b7f7d7511d83dc1db3c1d0072da0841ef7

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
