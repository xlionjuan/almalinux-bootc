FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:1cff16534704db8d096787cb27b44b9150d05b9ad4945ae27680e002c337c06b

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
