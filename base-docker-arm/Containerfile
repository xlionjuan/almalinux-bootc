FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:a9f86c265aaa6993132a1e99803a9fe92231a7456b6843e38d3c7faa792bc6ca

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
