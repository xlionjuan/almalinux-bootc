FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:75e69a7e594aa635ae8346194c8f0da845499068031df344d590e8b4f5efe88e

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
