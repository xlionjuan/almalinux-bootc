FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:97c7c90db5dbb710dc75ef3d9a5a6f448afd9cf9c936e7def4d786db517d332e

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
