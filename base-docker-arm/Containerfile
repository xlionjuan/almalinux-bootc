FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:aedf211f0a91505edbed2cdfb8c46ed00185ef95029fa5f8f826d981c91fe40a

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
