FROM ghcr.io/xlionjuan/almalinux-bootc:base-arm@sha256:23c83c87687df85407eb6aa2eddf5acf99091fcb971bed56859999496c944583

COPY build.sh /tmp/build.sh

RUN mkdir -p /var/lib/alternatives && \
    /tmp/build.sh && \
    dnf clean all && \
    rm -rf /var/log/* && \
    ostree container commit

RUN bootc container lint
